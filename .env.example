# Plaud API credentials — copy from web.plaud.ai cURL
# Use `uv run plaud onboard` to generate this file from a pasted cURL.

PLAUD_AUTHORIZATION=
PLAUD_X_DEVICE_ID=
PLAUD_X_PLD_TAG=
PLAUD_X_PLD_USER=

PLAUD_BASE_URL=https://api-apne1.plaud.ai
PLAUD_APP_LANGUAGE=en
PLAUD_APP_PLATFORM=web
PLAUD_EDIT_FROM=web
PLAUD_ORIGIN=https://web.plaud.ai
PLAUD_REFERER=https://web.plaud.ai/
PLAUD_TIMEZONE=Asia/Seoul
